{
  "name": "ccrcm-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:web": "npm --prefix ./web install && npm --prefix ./web run build",
    "build:all": "npm run build:web && npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/formbody": "^8.0.0",
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
