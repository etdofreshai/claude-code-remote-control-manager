CCRC_SERVER_URL=http://localhost:3000
CCRC_TOKEN=change-me
CCRC_NAME=desktop
# Optional: default | bypassPermissions | acceptEdits | plan | auto | dontAsk
# CCRC_PERMISSION_MODE=bypassPermissions
# Optional for `npm run claude-ai:sessions`: defaults to ~/.claude/.credentials.json
# CLAUDE_CREDENTIALS_PATH=/path/to/.claude/.credentials.json
# Optional for Claude.ai proxy calls when required by upstream.
# CLAUDE_AI_ORGANIZATION_UUID=your-organization-uuid
