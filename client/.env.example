SERVER_URL=https://ccrcm.etdofresh.com
CLIENT_TOKEN=shared-token
AGENT_NAME=my-laptop
DEFAULT_WORKING_DIRECTORY=/home/node/workspace

# Default reasoning effort for new sessions (low | medium | high | xhigh | max)
REASONING_EFFORT=low

# Default provider for new sessions
DEFAULT_PROVIDER=claude

# JSON map of provider configs. "claude" can omit baseUrl/authToken to use
# native ~/.claude auth. Other providers point at a LiteLLM, Switchboard,
# or any Anthropic-compatible gateway.
#
# Example:
# PROVIDERS_JSON={"claude":{"models":["claude-sonnet-4-5","claude-opus-4-7"]},"codex":{"baseUrl":"https://litellm.example/v1","authToken":"sk-litellm-...","models":["gpt-5","gpt-5-mini"]},"glm":{"baseUrl":"https://litellm.example/v1","authToken":"sk-litellm-...","models":["glm-4.6"]}}
PROVIDERS_JSON={"claude":{"models":[]}}

# Switchboard gateway (https://switchboard.etdofresh.com). Anthropic-compatible
# at the root URL; routes by "switchboard/<name>" model ids to Claude, GLM,
# Gemini, GPT, Codex, etc. The gateway currently accepts any non-empty token.
SWITCHBOARD_BASE_URL=https://switchboard.etdofresh.com
SWITCHBOARD_API_KEY=switchboard
